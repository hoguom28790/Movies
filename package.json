{
  "name": "temp-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:local": "next build && xcopy /E /I /Y public .next\\standalone\\public && xcopy /E /I /Y .next\\static .next\\standalone\\.next\\static",
    "start": "next start",
    "start:local": "node .next/standalone/server.js",
    "lint": "eslint",
    "clean": "powershell -Command \"Remove-Item -Path .next, .turbo -Recurse -Force -ErrorAction SilentlyContinue\"",
    "clean:all": "powershell -Command \"Remove-Item -Path .next, .turbo, node_modules -Recurse -Force -ErrorAction SilentlyContinue\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.91.3",
    "firebase": "^12.10.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
